<!doctype html><html lang="ru"><head><meta charset="utf-8"><meta name="csrf-token" content="<%= csrfToken %>"><meta name="viewport" content="width=device-width,initial-scale=1"><link rel="stylesheet" href="/kotocats-core/css/internal-tools.css"><script defer src="/kotocats-core/js/internal-tools.js"></script><script defer src="/kotocats-core/js/partners-editor.js"></script><script type="application/json" id="internal-tools-bootstrap"><%- JSON.stringify({ api: { partners: "/api/tools/partners" } }).replace(/</g, "\u003c") %></script><title>Партнёры</title></head><body><main class="it-page"><h1>Редактор партнёров</h1><p id="it-status" class="it-status" aria-live="polite"></p><div class="it-editor"><section><h2>Партнёры</h2><div id="it-partners" class="it-list" aria-live="polite"></div></section><section><h2 id="it-form-title">Новый партнёр</h2><form id="it-form"><input type="hidden" name="slug"><label>Идентификатор<input name="slugInput" required pattern="[a-z0-9][a-z0-9-]*"></label><label>Название<input name="name" required></label><label>Ссылка<input name="url" type="url" required></label><label>Логотип<input name="logo" required><input name="logoFile" type="file" accept="image/png,image/jpeg,image/webp"></label><img id="it-preview" class="it-preview" alt="Предпросмотр логотипа"><label>Тип<input name="type" value="partner"></label><label>Описание<textarea name="description"></textarea></label><label>Сортировка<input name="priority" type="number"></label><label><input name="active" type="checkbox" checked> Активен</label><label><input name="show_on_foundation" type="checkbox" checked> Показывать на сайте фонда</label><label><input name="show_on_cafe" type="checkbox" checked> Показывать на сайте кафе</label><div class="it-actions"><button type="submit">Сохранить</button><button type="button" id="it-cancel">Отменить</button></div></form></section></div></main></body></html>
