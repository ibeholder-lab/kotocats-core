<%
const catMediaGallery = Array.isArray(cat.mediaGallery) ? cat.mediaGallery : [];
const hasMultipleCatMedia = catMediaGallery.length > 1;
%>

<div class="kgorod-cat-detail" id="cat-detail">
  <div class="kgorod-cat-detail__media kgv-cover-media">
    <% if (hasMultipleCatMedia) { %>
      <button
        class="kgv-cover-media-prev kgorod-cat-media-arrow kgorod-cat-media-arrow--prev"
        type="button"
        aria-label="Предыдущее фото или видео">
        ‹
      </button>
    <% } %>

    <% if (cat.photoUrl) { %>
      <img
        src="<%= cat.photoUrl %>"
        alt="<%= cat.name %>"
        loading="eager"
        fetchpriority="high"
        decoding="async">
    <% } %>

    <% if (hasMultipleCatMedia) { %>
      <button
        class="kgv-cover-media-next kgorod-cat-media-arrow kgorod-cat-media-arrow--next"
        type="button"
        aria-label="Следующее фото или видео">
        ›
      </button>
    <% } %>
  </div>

  <div class="kgorod-cat-detail__body">
    <a class="kgorod-cat-detail__back" href="<%= catsUrl || '/cats' %>">
      ← Все кошки
    </a>

    <p class="kgorod-cat-detail__status">
      <%= cat.statusLabel || 'Ищет дом' %>
    </p>

    <h1 class="kgorod-cat-detail__name"><%= cat.name %></h1>

    <% if (cat.facts && cat.facts.length) { %>
      <div class="kgorod-cat-detail__facts">
        <% cat.facts.forEach(function(fact) { %>
          <span class="kgorod-cats__fact"><%= fact %></span>
        <% }) %>
      </div>
    <% } %>

    <% if (cat.description) { %>
      <p class="kgorod-cat-detail__desc"><%= cat.description %></p>
    <% } %>

    <div class="kgorod-cat-detail__actions">
      <a class="kgv-btn kgv-btn-dark" href="<%= helpUrl || '/help' %>">
        <%= helpText || 'Помочь кошкам' %>
      </a>

      <a class="kgv-btn" href="<%= meetUrl || '/kotocafe' %>">
        <%= meetText || 'Приехать знакомиться' %>
      </a>
    </div>
  </div>
</div>
