<%
  const galleryItems =
    Array.isArray(mediaGallery)
      ? mediaGallery
      : Array.isArray(cat.mediaGallery)
        ? cat.mediaGallery
        : [];

  const currentGalleryId =
    typeof galleryId === "string" && galleryId
      ? galleryId
      : "main";

  const currentGalleryLabel =
    typeof galleryLabel === "string" && galleryLabel
      ? galleryLabel
      : `Фото и видео ${cat.name}`;

  const hideFirstItem =
    typeof hideFirst === "boolean"
      ? hideFirst
      : currentGalleryId === "main";
%>

<% if (galleryItems.length) { %>

  <section
    class="kgorod-cat-media-strip"
    data-gallery-id="<%= currentGalleryId %>"
    aria-label="<%= currentGalleryLabel %>">

    <% galleryItems.forEach(function(media, index) { %>

      <%
        const isCoverSource =
          currentGalleryId === "main" &&
          index === 0;

        const shouldHide =
          hideFirstItem &&
          index === 0;
      %>

      <% if (media.type === "video") { %>

        <a
          class="kgorod-cat-media-strip__item cat-gallery-lightbox kgorod-cat-media-strip__item--video <%= isCoverSource ? 'is-cover-source' : '' %>"
          href="<%= media.fullUrl %>"
          data-gallery="cat-gallery-<%= currentGalleryId %>"
          data-type="video"
          data-media-kind="video"
          data-full-src="<%= media.fullUrl %>"
          data-poster="<%= media.poster || '' %>"
          data-gallery-index="<%= index %>"
          data-media-type="animal_media"
          data-media-id="<%= media.id %>"
          <%= shouldHide ? 'hidden' : '' %>
          aria-label="Открыть видео <%= cat.name %>">

          <span class="cat-gallery-like-badge" data-gallery-like-badge aria-hidden="true"><svg data-like-heart viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1.1-1.1a5.5 5.5 0 0 0-7.8 7.8L12 21l8.9-8.6a5.5 5.5 0 0 0-.1-7.8Z"/></svg><span data-like-count>0</span></span>

          <video
            muted
            loop
            playsinline
            preload="none"
            poster="<%= media.poster || '' %>">

            <% if (media.thumbWebm) { %>
              <source
                src="<%= media.thumbWebm %>"
                type="video/webm">
            <% } %>

            <% if (media.thumbMp4) { %>
              <source
                src="<%= media.thumbMp4 %>"
                type="video/mp4">
            <% } %>

          </video>

          <span
            class="kgorod-cat-media-strip__play"
            aria-hidden="true">
            ▶
          </span>

        </a>

      <% } else { %>

        <a
          class="kgorod-cat-media-strip__item cat-gallery-lightbox <%= isCoverSource ? 'is-cover-source' : '' %>"
          href="<%= media.fullUrl %>"
          data-gallery="cat-gallery-<%= currentGalleryId %>"
          data-type="image"
          data-media-kind="photo"
          data-full-src="<%= media.fullUrl %>"
          data-thumb-src="<%= media.thumbUrl %>"
          data-gallery-index="<%= index %>"
          data-media-type="animal_media"
          data-media-id="<%= media.id %>"
          <%= shouldHide ? 'hidden' : '' %>
          aria-label="Открыть фото <%= cat.name %>">

          <span class="cat-gallery-like-badge" data-gallery-like-badge aria-hidden="true"><svg data-like-heart viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1.1-1.1a5.5 5.5 0 0 0-7.8 7.8L12 21l8.9-8.6a5.5 5.5 0 0 0-.1-7.8Z"/></svg><span data-like-count>0</span></span>

          <img
            src="<%= media.thumbUrl %>"
            alt="<%= cat.name %> — фото <%= index + 1 %>"
            loading="lazy"
            decoding="async">

        </a>

      <% } %>

    <% }) %>

  </section>

<% } %>