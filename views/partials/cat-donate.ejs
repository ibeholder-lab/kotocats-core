<%
const paymentData = typeof paymentQuery !== "undefined" ? paymentQuery : {};
const paymentSuccess = String(paymentData.payment || "") === "success";
const catDonateName = cat && cat.name ? `кошку по имени ${cat.name}` : "кошку";
const donateKind = typeof donationKind !== "undefined" ? donationKind : "donate";
const donationNeedId = typeof needId !== "undefined" ? needId : "";
const donationNeedTitle = typeof needTitle !== "undefined" ? needTitle : "";
const donationAmounts =
  typeof amounts !== "undefined" && Array.isArray(amounts) && amounts.length
    ? amounts
    : [50, 100, 300];
const defaultAmount = Number(typeof initialAmount !== "undefined" ? initialAmount : donationAmounts[donationAmounts.length - 1]) || 300;
%>

<% if (!paymentSuccess) { %>
  <section
    class="cat-donate"
    data-cat-donate
    data-cat-id="<%= cat.id %>"
    data-cat-name="<%= cat.name %>"
    data-donation-kind="<%= donateKind %>"
    data-need-id="<%= donationNeedId %>"
    data-need-title="<%= donationNeedTitle %>"
    data-success-url="<%= pageUrl %>?payment=success&kind=donate"
    data-failure-url="<%= pageUrl %>?payment=failed&kind=donate">

    <div class="cat-donate__content">
      <p class="cat-donate__eyebrow">
        <%= donateEyebrow || 'Помочь кошке' %>
      </p>

      <h2 class="cat-donate__title">
        Поддержать <%= catDonateName %>
      </h2>

      <p class="cat-donate__text" data-donate-text>
        <%= donateText || 'Ваш донат помогает оплачивать корм, лекарства, обследования и ежедневный уход.' %>
      </p>

      <div class="cat-donate__amounts" aria-label="Выберите сумму пожертвования">
        <% donationAmounts.forEach(function(amount) { %>
          <button type="button" class="cat-donate__amount <%= Number(amount) === defaultAmount ? 'is-active' : '' %>" data-amount="<%= amount %>"><%= amount %> ₽</button>
        <% }) %>
      </div>

      <div class="cat-donate__actions-row">
        <button type="button" class="cat-donate__button" data-donate-button>
          <%= donateKind === 'guardianship' ? 'Оформить опеку' : 'Помочь на ' + defaultAmount + ' ₽' %>
        </button>
      </div>
    </div>
  </section>
<% } %>
